# ============================================================
# Aike — variabili d'ambiente Cloudflare Pages Functions
# Configurare nel dashboard Cloudflare Pages → Settings → Environment variables.
# Mai committare i valori reali. Mai esporre le service/secret key lato client.
# ============================================================

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # service role key (solo lato Functions) — nome uniformato
SUPABASE_SERVICE_KEY=                 # legacy alias (alcune function vecchie lo leggono)

# Groq (piano Free, /api/groq-chat)
GROQ_API_KEY=

# Anthropic (chat agent multi-modello, /api/chat-agent)
# Modelli: haiku=claude-haiku-4-5, sonnet=claude-sonnet-4-6, opus=claude-opus-4-8
ANTHROPIC_API_KEY=

# Stripe (webhook /api/stripe-webhook)
STRIPE_WEBHOOK_SECRET=                # whsec_... firma del webhook (obbligatorio)
STRIPE_PRICE_PRO=                     # price_... piano Pro €14 → 350 crediti
STRIPE_PRICE_MAX=                     # price_... piano Max €49 → 1200 crediti
STRIPE_SECRET_KEY=                    # sk_... opzionale: lookup subscription/customer via API
