# ─── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ─── Notion ───────────────────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=

# Module 1 — Leads database ID
# Found in the Notion database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_LEADS_DB_ID=

# Module 2 — Quotes database ID
# Schema: Name (title), Client (rich_text), Email (email), Amount (number),
#         Status (select: Draft|Sent|Accepted|Rejected|Expired),
#         Due Date (date), Notes (rich_text), Created (created_time)
NOTION_QUOTES_DB_ID=

# Module 3 — Tasks database ID
# Schema: Name (title), Description (rich_text), Status (select: Todo|In Progress|Done|Blocked),
#         Priority (select: High|Medium|Low), Due Date (date),
#         Assigned To (rich_text), Created (created_time)
NOTION_TASKS_DB_ID=

# ─── Operator ─────────────────────────────────────────────────────────────────
# Telegram chat ID of the operator who receives alerts and daily briefs
# Get it by messaging @userinfobot on Telegram
OPERATOR_CHAT_ID=

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Secret token to authenticate Make.com webhook calls
WEBHOOK_SECRET=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
